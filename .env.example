# ── WasteGuard Society AI — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env

# ── GEMINI (Google Antigravity Agent) ──────────────────────────────────────
# Required for antigravity_agent.py — get free key at: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GROQ (Free LLM for CrewAI WhatsApp replies) ────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TWILIO (WhatsApp Sandbox) ───────────────────────────────────────────────
# Get free account at: https://www.twilio.com/try-twilio
# Sandbox number is always: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── SOCIETY CONTACT NUMBERS ─────────────────────────────────────────────────
# These numbers receive alerts from the Alert Agent
RWA_WHATSAPP_NUMBER=+91XXXXXXXXXX
GUARD_WHATSAPP_NUMBER=+91XXXXXXXXXX
